{
  "name": "@vpauto/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:admin": "VITE_VPAUTO_EXTENSION_ROLE=owner VITE_VPAUTO_OUTPUT_DIR=.output-admin VITE_VPAUTO_API_URL=http://localhost:3456 wxt build",
    "build:user": "VITE_VPAUTO_EXTENSION_ROLE=user VITE_VPAUTO_OUTPUT_DIR=.output-user VITE_VPAUTO_API_URL=${VITE_VPAUTO_API_URL:?Set VITE_VPAUTO_API_URL=https://api.your-domain.com} wxt build",
    "build:user:local": "VITE_VPAUTO_EXTENSION_ROLE=user VITE_VPAUTO_OUTPUT_DIR=.output-user-local VITE_VPAUTO_API_URL=http://localhost:3456 wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:admin": "VITE_VPAUTO_EXTENSION_ROLE=owner VITE_VPAUTO_OUTPUT_DIR=.output-admin VITE_VPAUTO_API_URL=http://localhost:3456 wxt zip",
    "zip:user": "VITE_VPAUTO_EXTENSION_ROLE=user VITE_VPAUTO_OUTPUT_DIR=.output-user VITE_VPAUTO_API_URL=${VITE_VPAUTO_API_URL:?Set VITE_VPAUTO_API_URL=https://api.your-domain.com} wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "test": "vitest run"
  },
  "dependencies": {
    "@vpauto/shared": "*",
    "chart.js": "^4.4.0",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wxt": "^0.19.0"
  }
}
